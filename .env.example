# Copy to .env.local for optional local testing only.
# On Vercel, set these in: Project → Settings → Environment Variables

# Required — generate with: openssl rand -hex 32
JWT_SECRET=

# Required on Vercel — auto-added when you connect Blob storage to the project
BLOB_READ_WRITE_TOKEN=

# Required — your live Vercel URL (no trailing slash)
SITE_URL=https://your-project.vercel.app

# Required for @mention email notifications — get from https://resend.com/api-keys
RESEND_API_KEY=

# Required for email — must be a verified domain in Resend (e.g. review@yourdomain.com)
# Test mode only: onboarding@resend.dev (sends only to your Resend account email)
RESEND_FROM_EMAIL=review@yourdomain.com
